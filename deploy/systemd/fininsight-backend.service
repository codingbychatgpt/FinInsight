[Unit]
Description=FinInsight FastAPI Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/fininsight/backend
EnvironmentFile=/opt/fininsight/backend/.env
ExecStart=/opt/fininsight/backend/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
